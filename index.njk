    </section>

    <!-- Credentials Section -->
    <section id="credentials">
      <div class="credentials-container">
        <div class="credential">Godkjent av DFØ som leverandør av opplæring for SOA Basis sertifisert innkjøper</div>
        <div class="credential-separator"></div>
        <div class="credential">Godkjent av Advokattilsynet som kursleverandør for etterutdanning av advokater</div>
      </div>
    </section>

    <!-- Siste Innsikt Articles — rendret ved byggetidspunkt, ikke JavaScript -->
    <section id="innsikt-artikler">
      <div class="section-container">
        <div class="innsikt-header">
          <h2 class="innsikt-title">Siste innsikt</h2>
          <a href="/innsikt/" class="innsikt-alle">Alle artikler →</a>
        </div>
        <div class="innsikt-list">
          {% set latest = collections.innsikt | reverse %}
          {% for article in latest %}
            {% if loop.index0 < 5 %}
            <a href="{{ article.url }}" class="innsikt-item">
              <div class="innsikt-item-date">{{ article.date | dato }}</div>
              <div class="innsikt-item-title">{{ article.data.title }}</div>
              {% if article.data.summary or article.data.excerpt %}
              <div class="innsikt-item-summary">{{ article.data.summary or article.data.excerpt }}</div>
              {% endif %}
            </a>
            {% endif %}
          {% endfor %}
          {% if collections.innsikt.length == 0 %}
            <p class="innsikt-empty">Ingen artikler ennå.</p>
          {% endif %}
        </div>
      </div>
    </section>

    <!-- Medlemskap Section -->
    <section id="live">
