  </header>
<!-- Main Content -->
  <main>
    <!-- Hero Section -->
    <section id="hero">
      <div class="section-container">
        <div class="hero-label">Forum for offentlige anskaffelser</div>
        <h1 class="hero-title">Norges ledende fagmiljø innen offentlige anskaffelser</h1>
        <p class="hero-text">Kurs, sertifisering og fagbøker for innkjøpere og leverandører.</p>
