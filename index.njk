    </section>

    <!-- Cards Section -->
    <section id="cards">
      <div class="section-container">
        <div class="cards-grid">
          <a href="kursside.html" class="card fade-in">
            <h3 class="card-title">Kurs for innkjøpere</h3>
            <p class="card-text">Webinarer og dagskurs i anskaffelsesrett, evalueringsmodeller, rammeavtaler og mer.</p>
            <div class="card-link">Les mer →</div>
